generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ContestVisibility {
  PUBLIC
  PRIVATE
  ARCHIVED
}

enum UploadAssetKind {
  POSTER
  INVITE_POSTER
  BANNER
  CERTIFICATE
  PROFILE_IMAGE
  LOGO
  EDITORIAL
}

enum CertificateType {
  PARTICIPATION
  WINNER
  CONTEST
}

enum FirstSolveStatus {
  ASSIGNED
  UNSOLVED
}

enum ContestStatusOverride {
  AUTO
  FORCE_UPCOMING
  FORCE_LIVE
  FORCE_COMPLETED
}

enum SyncStatus {
  IDLE
  RUNNING
  SUCCESS
  FAILED
}

model Admin {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  passwordHash String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  contests     Contest[]
  activityLogs ActivityLog[]
}

model Player {
  id              String                 @id @default(cuid())
  fullName        String
  username        String                 @unique
  email           String?                @unique
  year            Int                    @default(1)
  branchCourse    String?
  avatar          String?
  bio             String?
  currentRating   Int                    @default(1200)
  peakRating      Int                    @default(1200)
  monthlyRank     Int?
  yearlyRank      Int?
  contestsPlayed  Int                    @default(0)
  totalSolved     Int                    @default(0)
  totalScore      Int                    @default(0)
  wins            Int                    @default(0)
  podiums         Int                    @default(0)
  firstSolves     Int                    @default(0)
  averageRank     Float?
  bestRank        Int?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  participations  ContestParticipation[]
  achievements    Achievement[]
  hallOfFame      HallOfFame[]
  standings       ContestStanding[]
  monthlyBoards   MonthlyLeaderboard[]
  yearlyBoards    YearlyLeaderboard[]
  ratingHistory   RatingHistory[]
  uploads         UploadAsset[]
  certificates    Certificate[]
  firstSolveRows  FirstSolve[]

  @@index([currentRating])
  @@index([year])
  @@index([monthlyRank])
  @@index([yearlyRank])
}

model Contest {
  id             String                 @id @default(cuid())
  title          String
  slug           String                 @unique
  description    String
  invitePoster   String?
  bannerPoster   String?
  contestBanner  String?
  platform       String                 @default("Codeforces")
  contestLink    String?
  startTime      DateTime
  duration       Int                    @default(120)
  statusOverride ContestStatusOverride  @default(AUTO)
  visibility     ContestVisibility      @default(PUBLIC)
  scoringSystem  String                 @default("TDCS_ELO_V1")
  prizePool      String?
  totalPoints    Int                    @default(0)
  standingsFinalizedAt DateTime?
  lastSyncedAt   DateTime?
  syncStatus     SyncStatus             @default(IDLE)
  syncMessage    String?
  createdById    String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  createdBy      Admin?                 @relation(fields: [createdById], references: [id], onDelete: SetNull)
  participations ContestParticipation[]
  standings      ContestStanding[]
  hallOfFame     HallOfFame[]
  uploads        UploadAsset[]
  ratingHistory  RatingHistory[]
  certificates   Certificate[]
  coordinators   ContestCoordinator[]
  problems       ContestProblem[]

  @@index([visibility, startTime])
  @@index([createdById])
}

model ContestProblem {
  id          String              @id @default(cuid())
  contestId   String
  code        String
  title       String?
  points      Int
  sortOrder   Int                 @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  contest     Contest             @relation(fields: [contestId], references: [id], onDelete: Cascade)
  firstSolves FirstSolve[]

  @@unique([contestId, code])
  @@index([contestId, sortOrder])
}

model FirstSolve {
  id             String         @id @default(cuid())
  problemId      String
  playerUsername String?
  status         FirstSolveStatus @default(ASSIGNED)
  createdAt      DateTime       @default(now())
  problem        ContestProblem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  player         Player?        @relation(fields: [playerUsername], references: [username], onDelete: Cascade)

  @@unique([problemId])
  @@index([playerUsername, createdAt])
}

model ContestCoordinator {
  id        String   @id @default(cuid())
  contestId String
  name      String
  role      String
  email     String?
  phone     String
  discord   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  contest   Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)

  @@index([contestId])
}

model ContestParticipation {
  id             String   @id @default(cuid())
  contestId      String
  playerUsername String
  joinedAt       DateTime @default(now())
  finalRank      Int?
  finalScore     Int      @default(0)
  solved         Int      @default(0)
  solveVector    Int[]    @default([])
  solvedProblems String[] @default([])
  rawScore       Int      @default(0)
  contestScore   Int      @default(0)
  penalty        Int      @default(0)
  ratingDelta    Int      @default(0)
  contest        Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)
  player         Player   @relation(fields: [playerUsername], references: [username], onDelete: Cascade)

  @@unique([contestId, playerUsername])
  @@index([playerUsername, joinedAt])
  @@index([contestId, finalRank])
}

model ContestStanding {
  id             String   @id @default(cuid())
  contestId      String
  playerUsername String
  rank           Int
  solved         Int
  solveVector    Int[]    @default([])
  solvedProblems String[] @default([])
  penalty        Int
  rawScore       Int
  contestScore   Int
  bonusPoints    Int      @default(0)
  finalScore     Int
  firstSolves    Int      @default(0)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  contest        Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)
  player         Player   @relation(fields: [playerUsername], references: [username], onDelete: Cascade)

  @@unique([contestId, playerUsername])
  @@index([rank])
  @@index([contestId, rank])
  @@index([playerUsername, finalScore])
}

model Achievement {
  id             String   @id @default(cuid())
  playerUsername String
  title          String
  description    String?
  earnedAt       DateTime @default(now())
  player         Player   @relation(fields: [playerUsername], references: [username], onDelete: Cascade)

  @@index([playerUsername, earnedAt])
}

model HallOfFame {
  id             String   @id @default(cuid())
  playerUsername String
  contestId      String?
  title          String
  score          Int      @default(0)
  badges         String   @default("[]")
  specialTitles  String   @default("[]")
  awardedAt      DateTime @default(now())
  player         Player   @relation(fields: [playerUsername], references: [username], onDelete: Cascade)
  contest        Contest? @relation(fields: [contestId], references: [id], onDelete: SetNull)

  @@index([awardedAt])
  @@index([playerUsername])
}

model MonthlyLeaderboard {
  id             String   @id @default(cuid())
  playerUsername String
  year           Int
  month          Int
  rank           Int
  totalScore     Int
  contests       Int
  wins           Int
  solved         Int
  firstSolves    Int
  averageRank    Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  player         Player   @relation(fields: [playerUsername], references: [username], onDelete: Cascade)

  @@unique([playerUsername, year, month])
  @@index([year, month, rank])
}

model YearlyLeaderboard {
  id             String   @id @default(cuid())
  playerUsername String
  year           Int
  rank           Int
  totalScore     Int
  contests       Int
  wins           Int
  solved         Int
  firstSolves    Int
  averageRank    Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  player         Player   @relation(fields: [playerUsername], references: [username], onDelete: Cascade)

  @@unique([playerUsername, year])
  @@index([year, rank])
}

model RatingHistory {
  id             String   @id @default(cuid())
  playerUsername String
  contestId      String?
  rating         Int
  delta          Int
  reason         String?
  createdAt      DateTime @default(now())
  player         Player   @relation(fields: [playerUsername], references: [username], onDelete: Cascade)
  contest        Contest? @relation(fields: [contestId], references: [id], onDelete: SetNull)

  @@index([playerUsername, createdAt])
  @@index([contestId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  adminId   String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())
  admin     Admin?   @relation(fields: [adminId], references: [id], onDelete: SetNull)

  @@index([adminId, createdAt])
  @@index([entity, entityId])
}

model UploadAsset {
  id        String          @id @default(cuid())
  kind      UploadAssetKind
  url       String
  publicId  String?
  provider  String          @default("cloudinary")
  contestId String?
  playerUsername String?
  createdAt DateTime        @default(now())
  contest   Contest?        @relation(fields: [contestId], references: [id], onDelete: Cascade)
  player    Player?         @relation(fields: [playerUsername], references: [username], onDelete: Cascade)

  @@index([kind, createdAt])
  @@index([contestId])
  @@index([playerUsername])
}

model Certificate {
  id        String          @id @default(cuid())
  type      CertificateType
  title     String
  playerUsername String?
  contestId String?
  assetUrl  String?
  issuedAt  DateTime        @default(now())
  metadata  Json?
  player    Player?         @relation(fields: [playerUsername], references: [username], onDelete: SetNull)
  contest   Contest?        @relation(fields: [contestId], references: [id], onDelete: SetNull)

  @@index([playerUsername, issuedAt])
  @@index([contestId, issuedAt])
}
