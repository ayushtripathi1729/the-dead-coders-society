generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ContestStatus {
  UPCOMING
  LIVE
  FINISHED
}

enum ContestVisibility {
  PUBLIC
  PRIVATE
  ARCHIVED
}

enum UploadAssetKind {
  POSTER
  INVITE_POSTER
  BANNER
  CERTIFICATE
  PROFILE_IMAGE
  LOGO
  EDITORIAL
}

enum CertificateType {
  PARTICIPATION
  WINNER
  CONTEST
}

model Admin {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  passwordHash String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  contests     Contest[]
  activityLogs ActivityLog[]
}

model Player {
  id              String                 @id @default(cuid())
  fullName        String
  username        String                 @unique
  email           String?                @unique
  year            Int                    @default(1)
  branchCourse    String?
  avatar          String?
  bio             String?
  currentRating   Int                    @default(1200)
  peakRating      Int                    @default(1200)
  monthlyRank     Int?
  yearlyRank      Int?
  contestsPlayed  Int                    @default(0)
  totalSolved     Int                    @default(0)
  totalScore      Int                    @default(0)
  wins            Int                    @default(0)
  podiums         Int                    @default(0)
  firstSolves     Int                    @default(0)
  averageRank     Float?
  bestRank        Int?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  participations  ContestParticipation[]
  achievements    Achievement[]
  hallOfFame      HallOfFame[]
  standings       ContestStanding[]
  monthlyBoards   MonthlyLeaderboard[]
  yearlyBoards    YearlyLeaderboard[]
  ratingHistory   RatingHistory[]
  uploads         UploadAsset[]
  certificates    Certificate[]
  firstSolveRows  FirstSolve[]
  problemFirstSolves ProblemFirstSolve[]

  @@index([currentRating])
  @@index([year])
  @@index([monthlyRank])
  @@index([yearlyRank])
}

model Contest {
  id             String                 @id @default(cuid())
  title          String
  slug           String                 @unique
  description    String
  invitePoster   String?
  bannerPoster   String?
  contestBanner  String?
  platform       String                 @default("Codeforces")
  contestLink    String?
  startTime      DateTime
  duration       Int                    @default(120)
  status         ContestStatus          @default(UPCOMING)
  visibility     ContestVisibility      @default(PUBLIC)
  scoringSystem  String                 @default("TDCS_ELO_V1")
  prizePool      String?
  totalPoints    Int                    @default(1000)
  standingsFinalizedAt DateTime?
  createdById    String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  createdBy      Admin?                 @relation(fields: [createdById], references: [id], onDelete: SetNull)
  participations ContestParticipation[]
  standings      ContestStanding[]
  hallOfFame     HallOfFame[]
  uploads        UploadAsset[]
  ratingHistory  RatingHistory[]
  certificates   Certificate[]
  coordinators   ContestCoordinator[]
  firstSolvesRows FirstSolve[]
  problems       ContestProblem[]

  @@index([status, startTime])
  @@index([visibility, startTime])
  @@index([createdById])
}

model ContestProblem {
  id          String              @id @default(cuid())
  contestId   String
  code        String
  title       String?
  sortOrder   Int                 @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  contest     Contest             @relation(fields: [contestId], references: [id], onDelete: Cascade)
  firstSolves ProblemFirstSolve[]

  @@unique([contestId, code])
  @@index([contestId, sortOrder])
}

model ProblemFirstSolve {
  id        String         @id @default(cuid())
  problemId String
  playerId  String
  createdAt DateTime       @default(now())
  problem   ContestProblem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  player    Player         @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([problemId, playerId])
  @@index([playerId, createdAt])
}

model ContestCoordinator {
  id        String   @id @default(cuid())
  contestId String
  name      String
  role      String
  email     String?
  phone     String
  discord   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  contest   Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)

  @@index([contestId])
}

model FirstSolve {
  id            String   @id @default(cuid())
  contestId     String
  problemCode   String
  playerId      String
  timestamp     DateTime
  pointsAwarded Int      @default(0)
  createdAt     DateTime @default(now())
  contest       Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)
  player        Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([contestId, problemCode, playerId])
  @@index([contestId, timestamp])
  @@index([playerId, timestamp])
}

model ContestParticipation {
  id          String   @id @default(cuid())
  contestId   String
  playerId    String
  joinedAt    DateTime @default(now())
  finalRank   Int?
  finalScore  Int      @default(0)
  solved      Int      @default(0)
  penalty     Int      @default(0)
  ratingDelta Int      @default(0)
  contest     Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([contestId, playerId])
  @@index([playerId, joinedAt])
  @@index([contestId, finalRank])
}

model ContestStanding {
  id          String   @id @default(cuid())
  contestId   String
  playerId    String
  rank        Int
  solved      Int
  penalty     Int
  rawScore    Int
  bonusPoints Int      @default(0)
  finalScore  Int
  firstSolves Int      @default(0)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  contest     Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([contestId, playerId])
  @@index([rank])
  @@index([contestId, rank])
  @@index([playerId, finalScore])
}

model Achievement {
  id          String   @id @default(cuid())
  playerId    String
  title       String
  description String?
  earnedAt    DateTime @default(now())
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId, earnedAt])
}

model HallOfFame {
  id            String   @id @default(cuid())
  playerId      String
  contestId     String?
  title         String
  score         Int      @default(0)
  badges        String   @default("[]")
  specialTitles String   @default("[]")
  awardedAt     DateTime @default(now())
  player        Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  contest       Contest? @relation(fields: [contestId], references: [id], onDelete: SetNull)

  @@index([awardedAt])
  @@index([playerId])
}

model MonthlyLeaderboard {
  id          String   @id @default(cuid())
  playerId    String
  year        Int
  month       Int
  rank        Int
  totalScore  Int
  contests    Int
  wins        Int
  solved      Int
  firstSolves Int
  averageRank Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, year, month])
  @@index([year, month, rank])
}

model YearlyLeaderboard {
  id          String   @id @default(cuid())
  playerId    String
  year        Int
  rank        Int
  totalScore  Int
  contests    Int
  wins        Int
  solved      Int
  firstSolves Int
  averageRank Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, year])
  @@index([year, rank])
}

model RatingHistory {
  id        String   @id @default(cuid())
  playerId  String
  contestId String?
  rating    Int
  delta     Int
  reason    String?
  createdAt DateTime @default(now())
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  contest   Contest? @relation(fields: [contestId], references: [id], onDelete: SetNull)

  @@index([playerId, createdAt])
  @@index([contestId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  adminId   String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())
  admin     Admin?   @relation(fields: [adminId], references: [id], onDelete: SetNull)

  @@index([adminId, createdAt])
  @@index([entity, entityId])
}

model UploadAsset {
  id        String          @id @default(cuid())
  kind      UploadAssetKind
  url       String
  publicId  String?
  provider  String          @default("cloudinary")
  contestId String?
  playerId  String?
  createdAt DateTime        @default(now())
  contest   Contest?        @relation(fields: [contestId], references: [id], onDelete: Cascade)
  player    Player?         @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([kind, createdAt])
  @@index([contestId])
  @@index([playerId])
}

model Certificate {
  id        String          @id @default(cuid())
  type      CertificateType
  title     String
  playerId  String?
  contestId String?
  assetUrl  String?
  issuedAt  DateTime        @default(now())
  metadata  Json?
  player    Player?         @relation(fields: [playerId], references: [id], onDelete: SetNull)
  contest   Contest?        @relation(fields: [contestId], references: [id], onDelete: SetNull)

  @@index([playerId, issuedAt])
  @@index([contestId, issuedAt])
}
