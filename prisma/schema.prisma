generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ContestVisibility {
  PUBLIC
  PRIVATE
  ARCHIVED
}

enum UploadAssetKind {
  POSTER
  INVITE_POSTER
  BANNER
  CERTIFICATE
  PROFILE_IMAGE
  LOGO
  EDITORIAL
}

enum CertificateType {
  PARTICIPATION
  WINNER
  CONTEST
  ACHIEVEMENT
  SEASON
  TEAM
}

enum FirstSolveStatus {
  ASSIGNED
  UNSOLVED
}

enum ContestStatusOverride {
  AUTO
  FORCE_UPCOMING
  FORCE_LIVE
  FORCE_COMPLETED
}

enum SyncStatus {
  IDLE
  RUNNING
  SUCCESS
  FAILED
}

enum PlayerRole {
  MEMBER
  ADMIN
}

enum AcademyDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum DiscussionScope {
  GENERAL
  CONTEST
  PROBLEM
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TeamRole {
  CAPTAIN
  MEMBER
}

model Admin {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  passwordHash String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  contests     Contest[]
  activityLogs ActivityLog[]
}

model Player {
  id              String                 @id @default(cuid())
  fullName        String
  username        String                 @unique
  email           String?                @unique
  year            Int                    @default(1)
  branchCourse    String?
  avatar          String?
  bio             String?
  role            PlayerRole             @default(MEMBER)
  currentRating   Int                    @default(1200)
  peakRating      Int                    @default(1200)
  ratingTitle     String                 @default("Pupil")
  monthlyRank     Int?
  yearlyRank      Int?
  contestsPlayed  Int                    @default(0)
  totalSolved     Int                    @default(0)
  totalScore      Int                    @default(0)
  wins            Int                    @default(0)
  podiums         Int                    @default(0)
  firstSolves     Int                    @default(0)
  averageRank     Float?
  bestRank        Int?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  participations  ContestParticipation[]
  achievements    Achievement[]
  hallOfFame      HallOfFame[]
  standings       ContestStanding[]
  monthlyBoards   MonthlyLeaderboard[]
  yearlyBoards    YearlyLeaderboard[]
  ratingHistory   RatingHistory[]
  titleHistory    RatingTitleHistory[]
  uploads         UploadAsset[]
  certificates    Certificate[]
  firstSolveRows  FirstSolve[]
  academyProgress AcademyProgress[]
  topicStats      PlayerTopicStat[]
  recommendations TrainingRecommendation[]
  teamMemberships TeamMembership[]
  seasonStandings  SeasonStanding[]
  institutionId   String?
  institution     Institution?           @relation(fields: [institutionId], references: [id], onDelete: SetNull)

  @@index([currentRating])
  @@index([ratingTitle])
  @@index([year])
  @@index([monthlyRank])
  @@index([yearlyRank])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([institutionId])
}

model Contest {
  id             String                 @id @default(cuid())
  title          String
  slug           String                 @unique
  description    String
  invitePoster   String?
  bannerPoster   String?
  contestBanner  String?
  platform       String                 @default("Codeforces")
  contestLink    String?
  startTime      DateTime
  duration       Int                    @default(120)
  statusOverride ContestStatusOverride  @default(AUTO)
  visibility     ContestVisibility      @default(PUBLIC)
  scoringSystem  String                 @default("TDCS_ELO_V1")
  prizePool      String?
  totalPoints    Int                    @default(0)
  standingsFinalizedAt DateTime?
  lastSyncedAt   DateTime?
  syncStatus     SyncStatus             @default(IDLE)
  syncMessage    String?
  createdById    String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  createdBy      Admin?                 @relation(fields: [createdById], references: [id], onDelete: SetNull)
  participations ContestParticipation[]
  standings      ContestStanding[]
  hallOfFame     HallOfFame[]
  uploads        UploadAsset[]
  ratingHistory  RatingHistory[]
  certificates   Certificate[]
  coordinators   ContestCoordinator[]
  problems       ContestProblem[]
  analytics      ContestAnalytics?
  seasonId       String?
  season         Season?                @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  editorial      ContestEditorial?
  discussions    DiscussionThread[]

  @@index([visibility, startTime])
  @@index([startTime])
  @@index([updatedAt])
  @@index([createdById])
  @@index([seasonId])
}

model ContestProblem {
  id          String              @id @default(cuid())
  contestId   String
  code        String
  title       String?
  points      Int
  sortOrder   Int                 @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  contest     Contest             @relation(fields: [contestId], references: [id], onDelete: Cascade)
  firstSolves FirstSolve[]

  @@unique([contestId, code])
  @@index([contestId, sortOrder])
}

model FirstSolve {
  id             String         @id @default(cuid())
  problemId      String
  playerUsername String?
  status         FirstSolveStatus @default(ASSIGNED)
  createdAt      DateTime       @default(now())
  problem        ContestProblem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  player         Player?        @relation(fields: [playerUsername], references: [username], onDelete: Cascade)

  @@unique([problemId])
  @@index([playerUsername, createdAt])
  @@index([status, createdAt])
}

model ContestCoordinator {
  id        String   @id @default(cuid())
  contestId String
  name      String
  role      String
  email     String?
  phone     String
  discord   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  contest   Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)

  @@index([contestId])
}

model ContestParticipation {
  id             String   @id @default(cuid())
  contestId      String
  playerUsername String
  joinedAt       DateTime @default(now())
  finalRank      Int?
  finalScore     Int      @default(0)
  solved         Int      @default(0)
  solveVector    Int[]    @default([])
  solvedProblems String[] @default([])
  rawScore       Int      @default(0)
  contestScore   Int      @default(0)
  penalty        Int      @default(0)
  ratingDelta    Int      @default(0)
  contest        Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)
  player         Player   @relation(fields: [playerUsername], references: [username], onDelete: Cascade)

  @@unique([contestId, playerUsername])
  @@index([playerUsername, joinedAt])
  @@index([contestId, finalRank])
}

model ContestStanding {
  id             String   @id @default(cuid())
  contestId      String
  playerUsername String
  rank           Int
  solved         Int
  solveVector    Int[]    @default([])
  solvedProblems String[] @default([])
  penalty        Int
  rawScore       Int
  contestScore   Int
  bonusPoints    Int      @default(0)
  finalScore     Int
  firstSolves    Int      @default(0)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  contest        Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)
  player         Player   @relation(fields: [playerUsername], references: [username], onDelete: Cascade)

  @@unique([contestId, playerUsername])
  @@index([rank])
  @@index([contestId, rank])
  @@index([playerUsername, finalScore])
  @@index([createdAt])
  @@index([updatedAt])
}

model Achievement {
  id             String   @id @default(cuid())
  playerUsername String
  code           String?
  category       String   @default("GENERAL")
  title          String
  description    String?
  contestId      String?
  earnedAt       DateTime @default(now())
  player         Player   @relation(fields: [playerUsername], references: [username], onDelete: Cascade)

  @@index([playerUsername, earnedAt])
  @@index([code])
  @@unique([playerUsername, code])
}

model HallOfFame {
  id             String   @id @default(cuid())
  playerUsername String
  contestId      String?
  title          String
  score          Int      @default(0)
  badges         String   @default("[]")
  specialTitles  String   @default("[]")
  awardedAt      DateTime @default(now())
  player         Player   @relation(fields: [playerUsername], references: [username], onDelete: Cascade)
  contest        Contest? @relation(fields: [contestId], references: [id], onDelete: SetNull)

  @@index([awardedAt])
  @@index([playerUsername])
  @@index([contestId, awardedAt])
}

model MonthlyLeaderboard {
  id             String   @id @default(cuid())
  playerUsername String
  year           Int
  month          Int
  rank           Int
  totalScore     Int
  contests       Int
  wins           Int
  solved         Int
  firstSolves    Int
  averageRank    Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  player         Player   @relation(fields: [playerUsername], references: [username], onDelete: Cascade)

  @@unique([playerUsername, year, month])
  @@index([year, month, rank])
}

model YearlyLeaderboard {
  id             String   @id @default(cuid())
  playerUsername String
  year           Int
  rank           Int
  totalScore     Int
  contests       Int
  wins           Int
  solved         Int
  firstSolves    Int
  averageRank    Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  player         Player   @relation(fields: [playerUsername], references: [username], onDelete: Cascade)

  @@unique([playerUsername, year])
  @@index([year, rank])
}

model RatingHistory {
  id             String   @id @default(cuid())
  playerUsername String
  contestId      String?
  rating         Int
  delta          Int
  reason         String?
  createdAt      DateTime @default(now())
  player         Player   @relation(fields: [playerUsername], references: [username], onDelete: Cascade)
  contest        Contest? @relation(fields: [contestId], references: [id], onDelete: SetNull)

  @@index([playerUsername, createdAt])
  @@index([contestId])
}

model RatingTitleHistory {
  id             String   @id @default(cuid())
  playerUsername String
  title          String
  rating         Int
  contestId      String?
  earnedAt       DateTime @default(now())
  player         Player   @relation(fields: [playerUsername], references: [username], onDelete: Cascade)

  @@index([playerUsername, earnedAt])
  @@index([contestId])
}

model ContestAnalytics {
  id             String   @id @default(cuid())
  contestId      String   @unique
  participants   Int      @default(0)
  totalSolves    Int      @default(0)
  averageScore   Float    @default(0)
  averageSolved  Float    @default(0)
  winnerUsername String?
  fastestUsername String?
  hardestProblemCode String?
  mostSolvedProblemCode String?
  unsolvedProblems String[] @default([])
  problemStats   Json     @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  contest        Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)

  @@index([winnerUsername])
  @@index([updatedAt])
}

model ActivityLog {
  id        String   @id @default(cuid())
  adminId   String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())
  admin     Admin?   @relation(fields: [adminId], references: [id], onDelete: SetNull)

  @@index([adminId, createdAt])
  @@index([entity, entityId])
  @@index([createdAt])
}

model UploadAsset {
  id        String          @id @default(cuid())
  kind      UploadAssetKind
  url       String
  publicId  String?
  provider  String          @default("cloudinary")
  contestId String?
  playerUsername String?
  createdAt DateTime        @default(now())
  contest   Contest?        @relation(fields: [contestId], references: [id], onDelete: Cascade)
  player    Player?         @relation(fields: [playerUsername], references: [username], onDelete: Cascade)

  @@index([kind, createdAt])
  @@index([contestId])
  @@index([playerUsername])
}

model Certificate {
  id        String          @id @default(cuid())
  type      CertificateType
  title     String
  playerUsername String?
  contestId String?
  assetUrl  String?
  issuedAt  DateTime        @default(now())
  metadata  Json?
  player    Player?         @relation(fields: [playerUsername], references: [username], onDelete: SetNull)
  contest   Contest?        @relation(fields: [contestId], references: [id], onDelete: SetNull)

  @@index([playerUsername, issuedAt])
  @@index([contestId, issuedAt])
}

model AcademyTopic {
  id              String                   @id
  slug            String                   @unique
  title           String
  overview        String
  sortOrder       Int                      @default(0)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  resources       AcademyResource[]
  problems        AcademyProblem[]
  progress        AcademyProgress[]
  topicStats      PlayerTopicStat[]
  recommendations TrainingRecommendation[]

  @@index([sortOrder])
}

model AcademyResource {
  id        String       @id @default(cuid())
  topicId   String
  title     String
  url       String
  kind      String       @default("ARTICLE")
  sortOrder Int          @default(0)
  topic     AcademyTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@index([topicId, sortOrder])
}

model AcademyProblem {
  id         String            @id @default(cuid())
  topicId    String
  title      String
  url        String?
  difficulty AcademyDifficulty @default(BEGINNER)
  rating     Int               @default(800)
  sortOrder  Int               @default(0)
  topic      AcademyTopic      @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@index([topicId, difficulty, sortOrder])
}

model AcademyProgress {
  id              String       @id @default(cuid())
  playerUsername  String
  topicId         String
  completed       Int          @default(0)
  total           Int          @default(0)
  lastPracticedAt DateTime?
  updatedAt       DateTime     @updatedAt
  player          Player       @relation(fields: [playerUsername], references: [username], onDelete: Cascade)
  topic           AcademyTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([playerUsername, topicId])
  @@index([topicId, updatedAt])
}

model PlayerTopicStat {
  id             String       @id @default(cuid())
  playerUsername String
  topicId        String
  attempts       Int          @default(0)
  solved         Int          @default(0)
  strengthScore  Float        @default(0)
  updatedAt      DateTime     @updatedAt
  player         Player       @relation(fields: [playerUsername], references: [username], onDelete: Cascade)
  topic          AcademyTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([playerUsername, topicId])
  @@index([playerUsername, strengthScore])
}

model TrainingRecommendation {
  id             String            @id @default(cuid())
  playerUsername String
  topicId        String?
  problemId      String?
  reason         String
  nextDifficulty AcademyDifficulty @default(BEGINNER)
  priority       Int               @default(0)
  createdAt      DateTime          @default(now())
  player         Player            @relation(fields: [playerUsername], references: [username], onDelete: Cascade)
  topic          AcademyTopic?     @relation(fields: [topicId], references: [id], onDelete: SetNull)

  @@index([playerUsername, priority])
  @@index([topicId])
}

model Season {
  id            String           @id
  name          String
  slug          String           @unique
  startsAt      DateTime
  endsAt        DateTime
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  contests      Contest[]
  standings     SeasonStanding[]
  teamStandings TeamStanding[]

  @@index([startsAt, endsAt])
}

model SeasonStanding {
  id             String   @id @default(cuid())
  seasonId       String
  playerUsername String
  rank           Int
  points         Int      @default(0)
  contests       Int      @default(0)
  wins           Int      @default(0)
  solved         Int      @default(0)
  rating         Int      @default(1200)
  updatedAt      DateTime @updatedAt
  season         Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  player         Player   @relation(fields: [playerUsername], references: [username], onDelete: Cascade)

  @@unique([seasonId, playerUsername])
  @@index([seasonId, rank])
  @@index([playerUsername])
}

model Team {
  id            String            @id @default(cuid())
  name          String
  slug          String            @unique
  institutionId String?
  rating        Int               @default(1200)
  points        Int               @default(0)
  wins          Int               @default(0)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  institution   Institution?      @relation(fields: [institutionId], references: [id], onDelete: SetNull)
  memberships   TeamMembership[]
  achievements  TeamAchievement[]
  standings     TeamStanding[]

  @@index([rating])
  @@index([points])
  @@index([institutionId])
}

model TeamMembership {
  id             String   @id @default(cuid())
  teamId         String
  playerUsername String
  role           TeamRole @default(MEMBER)
  joinedAt       DateTime @default(now())
  team           Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  player         Player   @relation(fields: [playerUsername], references: [username], onDelete: Cascade)

  @@unique([teamId, playerUsername])
  @@index([playerUsername])
}

model TeamStanding {
  id        String   @id @default(cuid())
  seasonId  String
  teamId    String
  rank      Int
  points    Int      @default(0)
  rating    Int      @default(1200)
  wins      Int      @default(0)
  updatedAt DateTime @updatedAt
  season    Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([seasonId, teamId])
  @@index([seasonId, rank])
}

model TeamAchievement {
  id       String   @id @default(cuid())
  teamId   String
  code     String
  title    String
  earnedAt DateTime @default(now())
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, code])
}

model ContestEditorial {
  id        String              @id @default(cuid())
  contestId String              @unique
  content   String              @default("")
  resources Json                @default("[]")
  updatedAt DateTime            @updatedAt
  contest   Contest             @relation(fields: [contestId], references: [id], onDelete: Cascade)
  revisions EditorialRevision[]
}

model EditorialRevision {
  id          String           @id @default(cuid())
  editorialId String
  content     String
  version     Int
  createdAt   DateTime         @default(now())
  editorial   ContestEditorial @relation(fields: [editorialId], references: [id], onDelete: Cascade)

  @@unique([editorialId, version])
}

model DiscussionThread {
  id          String           @id @default(cuid())
  scope       DiscussionScope  @default(GENERAL)
  contestId   String?
  problemCode String?
  title       String
  status      ModerationStatus @default(APPROVED)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  contest     Contest?         @relation(fields: [contestId], references: [id], onDelete: Cascade)
  posts       DiscussionPost[]

  @@index([scope, status, updatedAt])
  @@index([contestId])
}

model DiscussionPost {
  id        String           @id @default(cuid())
  threadId  String
  author    String
  body      String
  status    ModerationStatus @default(PENDING)
  createdAt DateTime         @default(now())
  thread    DiscussionThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, status, createdAt])
  @@index([status, createdAt])
}

model Institution {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  departments String[] @default([])
  batches     String[] @default([])
  createdAt   DateTime @default(now())
  players     Player[]
  teams       Team[]
}
